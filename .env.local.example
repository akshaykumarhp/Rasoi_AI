# Google AI Studio (free) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase (free) — https://supabase.com/dashboard  Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: override the Gemini free-model rotation order (comma-separated).
# Each model has its own daily quota, so rotating multiplies effective RPD.
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-flash,gemini-1.5-flash-8b

# Optional: local Ollama fallback when ALL Gemini models are rate-limited.
# Requires Ollama running with the model pulled:  ollama pull llama3.1
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
